{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{js,ts}"
      ],
      "ignore": [
        "uno.config.ts"
      ]
    },
    "apps/docs": {
      "entry": [
        "src/App.vue",
        "src/components/**/*.vue",
        "src/composables/*.ts",
        "src/constants/*.ts",
        "src/data/**/*.ts",
        "src/plugins/*.ts",
        "src/stores/*.ts",
        "src/layouts/*.vue",
        "src/pages/**/*.{vue,md}",
        "build/**/*.ts",
        "vite.config.*",
        "src/examples/**/*.vue"
      ],
      "ignore": [
        "src/typed-router.d.ts",
        "src/examples/guide/building-frameworks/my-ui/src/**/*.ts",
        "src/examples/guide/building-frameworks/my-ui/vite.config.ts",
        "src/examples/composables/create-trinity/toasts.ts",
        "src/skillz/tours/**/index.ts"
      ],
      "paths": {
        "@/*": [
          "src/*"
        ],
        "@vuetify/v0": [
          "../../packages/0/src"
        ],
        "@vuetify/paper": [
          "../../packages/paper/src"
        ],
        "#v0": [
          "../../packages/0/src"
        ],
        "#paper": [
          "../../packages/paper/src"
        ]
      }
    },
    "packages/0": {
      "entry": [
        "src/*/adapters/**/*.ts",
        "src/composables/*/adapters/**/*.ts",
        "scripts/**/*.ts"
      ],
      "project": [
        "src/**/*.{ts,vue}",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ],
      "ignore": [
        "src/**/*.bench.ts"
      ],

      "paths": {
        "#v0/*": [
          "src/*"
        ]
      }
    },
    "packages/paper": {
      "project": [
        "src/**/*.{ts,vue}",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ],
      "ignore": [
        "src/**/helpers.ts"
      ],
      "ignoreDependencies": [
        "sass"
      ]
    },
    "apps/playground": {
      "entry": [
        "src/App.vue",
        "src/components/**/*.vue",
        "src/composables/*.ts",
        "src/plugins/*.ts",
        "src/layouts/*.vue",
        "src/pages/**/*.{vue,md}",
        "vite.config.*"
      ],
      "ignore": [
        "src/typed-router.d.ts",
        "src/util/export-templates/**"
      ],
      "paths": {
        "@/*": [
          "src/*"
        ],
        "@vuetify/v0": [
          "../../packages/0/src"
        ],
        "#v0": [
          "../../packages/0/src"
        ]
      }
    },
    "dev": {
      "entry": [],
      "project": [
        "**/*.{js,ts,vue}",
        "src/composables.d.ts",
        "src/components.d.ts"
      ],
      "ignore": [
        "src/Playground.template.vue"
      ],
      "paths": {
        "@/*": [
          "src/*"
        ],
        "@vuetify/v0": [
          "../packages/0/src"
        ],
        "@vuetify/paper": [
          "../packages/paper/src"
        ],
        "#v0": [
          "../packages/0/src"
        ],
        "#paper": [
          "../packages/paper/src"
        ]
      }
    }
  },
  "ignore": [
    "**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@js-temporal/polyfill",
    "@vue/repl",
    "@vuetify/paper",
    "conventional-changelog-vuetify",
    "@vue/compiler-dom",
    "pkg-pr-new"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": [
    "pkg-pr-new"
  ]
}
