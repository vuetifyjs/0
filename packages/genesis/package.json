{
  "name": "@paper/genesis",
  "version": "1.0.0-beta.0",
  "description": "Genesis Design System — minimal docs primitives extracted from the v0 docs site",
  "license": "MIT",
  "types": "./dist/index.d.mts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "vue-tsc --noEmit --incremental"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
