    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json",
      "./style.css": "./dist/style.css"
    }
  },
  "dependencies": {
    "@vuetify/v0": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:"
  }
