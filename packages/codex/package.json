{
  "name": "@paper/codex",
  "version": "0.1.0",
  "description": "Documentation Design System — batteries-included components for building docs",
  "license": "MIT",
  "types": "./dist/index.d.mts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "vue-tsc --noEmit --incremental"
  },
  "peerDependencies": {
    "unocss": ">=0.65.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "unocss": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json",
      "./style.css": "./dist/style.css"
    }
  },
  "dependencies": {
    "@vuetify/paper": "workspace:*",
    "@vuetify/v0": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:"
  }
}
