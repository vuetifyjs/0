{
  "name": "@vuetify/zero",
  "version": "1.0.0-beta.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter=dev dev",
    "dev:docs": "pnpm --filter=docs dev",
    "build": "pnpm --filter=\"./packages/*\" build",
    "build:0": "pnpm --filter=\"./packages/0\" build",
    "build:paper": "pnpm --filter=\"./packages/paper\" build",
    "build:packages": "pnpm --filter=\"./packages/*\" build",
    "build:dev": "pnpm --filter=dev build",
    "build:play": "pnpm --filter=@vuetify-private/playground build",
    "build:docs": "pnpm --filter=docs build",
    "build:apps": "pnpm --filter=docs --filter=dev --filter=@vuetify-private/playground build",
    "build:all": "pnpm --filter=\"./packages/*\" --filter=docs --filter=dev --filter=@vuetify-private/playground build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:vapor": "pnpm --filter=@vuetify-private/vapor-tests test",
    "test:bench": "vitest --reporter=verbose bench --run --project v0:unit --maxWorkers=1 --no-file-parallelism",
    "test:ssr": "vitest run --reporter=verbose hydration",
    "test:bench:json": "vitest bench --run --project v0:unit --maxWorkers=1 --no-file-parallelism --outputJson apps/docs/public/benchmarks.json",
    "bench": "vitest --reporter=default bench --project v0:unit --maxWorkers=1 --no-file-parallelism",
    "metrics": "pnpm exec vitest run --coverage --project v0:unit && pnpm build:0 && pnpm metrics:bench && node scripts/generate-metrics.js",
    "metrics:bench": "V0_BENCH_TARGET=dist node scripts/run-bench-stable.ts --runs 3 --out apps/docs/public/benchmarks.json",
    "metrics:history": "node scripts/generate-metrics-history.ts",
    "metrics:check": "node scripts/check-benchmark-artifacts.ts",
    "metrics:delta": "node scripts/report-benchmark-delta.ts",
    "skill": "node scripts/generate-skill.ts",
    "typecheck": "pnpm --filter=\"./packages/*\" typecheck",
    "typecheck:0": "pnpm --filter=\"./packages/0\" typecheck",
    "typecheck:paper": "pnpm --filter=\"./packages/paper\" typecheck",
    "lint": "eslint --concurrency auto",
    "lint:fix": "eslint --fix --concurrency auto",
    "dev:play": "pnpm --filter=@vuetify-private/playground dev",
    "preview:dev": "pnpm --filter=dev preview",
    "preview:play": "pnpm --filter=@vuetify-private/playground preview",
    "preview:docs": "pnpm --filter=docs preview",
    "repo:knip": "knip",
    "repo:sherif": "sherif",
    "repo:exports": "publint ./packages/0 && attw --pack ./packages/0 --profile esm-only",
    "repo:check": "pnpm repo:knip && pnpm repo:sherif",
    "size": "size-limit",
    "validate": "pnpm lint && pnpm typecheck && pnpm test:run",
    "changeset": "changeset",
    "release": "pnpm build && node scripts/changeset-publish.js",
    "release:prepare": "pnpm validate && pnpm build",
    "postinstall": "node apps/docs/build/generate-api-whitelist.ts && node scripts/init-dev.js",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm lint && pnpm typecheck && pnpm test:run --project '!v0:browser' && pnpm repo:check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@js-temporal/polyfill": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/tsconfig": "catalog:",
    "eslint": "catalog:",
    "eslint-config-vuetify": "catalog:",
    "eslint-plugin-vuejs-accessibility": "catalog:",
    "happy-dom": "catalog:",
    "knip": "catalog:",
    "playwright": "catalog:",
    "publint": "catalog:",
    "sherif": "catalog:",
    "simple-git-hooks": "catalog:",
    "size-limit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=26"
  },
  "web-types": "dist/json/web-types.json"
}
